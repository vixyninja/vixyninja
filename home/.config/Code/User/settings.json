{
  // =========================================
  // WORKBENCH UI
  // =========================================
  "workbench.startupEditor": "none",
  "workbench.editor.labelFormat": "default",
  "workbench.list.smoothScrolling": true,
  "workbench.editor.wrapTabs": true,
  "workbench.editor.tabSizing": "fixed",
  "workbench.editor.defaultBinaryEditor": "default",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.productIconTheme": "material-product-icons",
  "workbench.tree.stickyScrollMaxItemCount": 4,
  "workbench.tree.indent": 4,
  "workbench.tree.enableStickyScroll": false,
  "workbench.tree.expandMode": "doubleClick",
  "workbench.tree.renderIndentGuides": "always",
  "workbench.colorCustomizations": {},
  // =========================================
  // WINDOW SETTINGS
  // =========================================
  "window.title": "${dirty}${activeEditorMedium}${separator}${rootName}${separator}",
  "window.titleSeparator": " 🎯 ",
  "window.zoomLevel": -0.5,
  // =========================================
  // EDITOR SETTINGS
  // =========================================
  "editor.formatOnPaste": true,
  "editor.detectIndentation": false,
  "editor.tabSize": 2,
  "editor.renderControlCharacters": false,
  "editor.renderLineHighlight": "gutter",
  "editor.rulers": [
    120
  ],
  "editor.unicodeHighlight.invisibleCharacters": false,
  "editor.minimap.enabled": true,
  "editor.hover.enabled": "on",
  "editor.fontSize": 14.5,
  "editor.lineHeight": 16.5,
  "editor.letterSpacing": 0,
  "editor.snippetSuggestions": "bottom",
  "editor.suggest.showClasses": true,
  "editor.suggest.showConstructors": true,
  "editor.suggest.showFunctions": true,
  "editor.suggest.showMethods": true,
  "editor.suggest.showProperties": true,
  "editor.suggest.showVariables": true,
  "editor.suggest.showConstants": true,
  "editor.suggest.showEnums": true,
  "editor.suggest.showEnumMembers": true,
  "editor.suggest.showKeywords": true,
  "editor.suggest.filterGraceful": true,
  "editor.suggest.showIcons": true,
  "editor.suggest.snippetsPreventQuickSuggestions": true,
  "editor.suggest.preview": true,
  "editor.suggest.showOperators": true,
  "editor.suggest.showStatusBar": true,
  "editor.suggest.showWords": true,
  "editor.suggest.showUnits": true,
  "editor.suggest.showUsers": true,
  "editor.suggest.showFiles": true,
  "editor.suggest.showTypeParameters": true,
  "editor.suggest.showValues": true,
  "editor.suggest.showStructs": true,
  "editor.suggest.showColors": true,
  "editor.suggest.showSnippets": true,
  "editor.suggest.showReferences": true,
  "editor.suggest.showModules": true,
  "editor.suggest.showIssues": true,
  "editor.suggest.showInlineDetails": true,
  "editor.suggest.showFolders": true,
  "editor.suggest.showFields": true,
  "editor.suggest.showEvents": true,
  "editor.suggest.showDeprecated": true,
  "editor.suggest.showCustomcolors": true,
  "editor.suggest.matchOnWordStartOnly": true,
  "editor.suggest.shareSuggestSelections": true,
  "editor.wordBasedSuggestions": "matchingDocuments",
  "editor.suggest.showInterfaces": true,
  "editor.suggest.localityBonus": true,
  "editor.acceptSuggestionOnCommitCharacter": false,
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.mouseWheelScrollSensitivity": 1,
  "editor.smoothScrolling": true,
  "editor.mouseWheelZoom": false,
  "editor.linkedEditing": true,
  "editor.fontFamily": "Monaco",
  "editor.fontLigatures": "'ss02', 'ss04'",
  "editor.glyphMargin": true,
  "editor.hover.sticky": true,
  "editor.hover.delay": 500,
  "editor.bracketPairColorization.enabled": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.fixAll": "explicit"
  },
  "editor.formatOnSave": true,
  "editor.suggestSelection": "first",
  "editor.inlineSuggest.enabled": true,
  "editor.codeLensFontFamily": "Monaco",
  "editor.codeLensFontSize": 16,
  "editor.inlayHints.fontSize": 16,
  "editor.guides.bracketPairs": "active",
  "editor.wordWrap": "wordWrapColumn",
  "editor.wordWrapColumn": 120,
  "editor.cursorSurroundingLines": 15,
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "phase",
  // =========================================
  // GIT AND GITHUB COPILOT SETTINGS
  // =========================================
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "always",
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "Log": false,
    "javascript": true,
    "dart": true,
    "csharp": true,
    "cpp": true
  },
  "git.confirmSync": false,
  "chat.editor.fontSize": 14.5,
  "github.copilot.nextEditSuggestions.enabled": true,
  "git.replaceTagsWhenPull": true,
  // =========================================
  // DEBUGGER SETTINGS
  // =========================================
  "debug.console.wordWrap": true,
  "debug.inlineValues": "on",
  "debug.console.fontFamily": "Monaco",
  "debug.console.fontSize": 16,
  "debug.console.lineHeight": 17.5,
  // =========================================
  // FILES & SEARCH SETTINGS
  // =========================================
  "files.defaultLanguage": "{activeEditorLanguage}",
  "files.exclude": {
    "USE_GITIGNORE": true,
    "**/*.spec.ts": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/coverage": true,
    "**/dist": true,
    "**/build": true,
    "**/.build": true,
  },
  // =========================================
  // TERMINAL SETTINGS
  // =========================================
  "terminal.integrated.copyOnSelection": false,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.fontFamily": "Monaco",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.drawBoldTextInBrightColors": false,
  "terminal.integrated.enableFileLinks": "on",
  // =========================================
  // GO SETTINGS
  // =========================================
  "go.useLanguageServer": true,
  "go.formatTool": "gofumpt",
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--fast"
  ],
  "go.testFlags": [
    "-v"
  ],
  "go.toolsManagement.autoUpdate": true,
  "go.buildFlags": [
    "-tags=wireinject"
  ],
  // =========================================
  // SPELL CHECKER SETTINGS
  // =========================================
  "cSpell.enabled": true,
  "cSpell.language": "en,pt,pt_BR,es,fr,vi",
  "cSpell.enabledFileTypes": {
    "*": true,
    "markdown": true
  },
  "cSpell.userWords": [
    "bycryptjs",
    "cloudinary",
    "metatype",
    "typeorm",
    "vixyninja"
  ],
  // =========================================
  // EXTENSIONS
  // =========================================
  // -------- Material Icon Theme --------
  "material-icon-theme.folders.color": "#42a5f5",
  "material-icon-theme.activeIconPack": "angular",
  "material-icon-theme.files.color": "#42a5f5",
  "material-icon-theme.opacity": 1,
  "material-icon-theme.saturation": 1,
  "material-icon-theme.hidesExplorerArrows": false,
  // -------- GitLens --------
  "gitlens.views.branches.files.layout": "list",
  "gitlens.gitCommands.skipConfirmations": [
    "fetch:command"
  ],
  "gitlens.views.repositories.showStashes": true,
  // -------- Red Hat --------
  "redhat.telemetry.enabled": true,
  // -------- Make / Build tools --------
  "makefile.configureOnOpen": false,
  // =========================================
  // FORMATTER PER LANGUAGE
  // =========================================
  "[handlebars]": {
    "editor.defaultFormatter": "vscode.html-language-features"
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[dockerfile]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go",
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  // =========================================
  // COMMENTS
  // =========================================
  "better-comments.tags": [
    {
      "tag": "!",
      "color": "#FF2D00",
      "strikethrough": false
    },
    {
      "tag": "?",
      "color": "#3498DB",
      "strikethrough": false
    },
    {
      "tag": "//",
      "color": "#474747",
      "strikethrough": true
    },
    {
      "tag": "todo",
      "color": "#FF8C00",
      "strikethrough": false
    },
    {
      "tag": "*",
      "color": "#98C379",
      "strikethrough": false
    },
    {
      "tag": "REMARK",
      "color": "#81E1B8",
      "strikethrough": false
    },
    {
      "tag": "DOCS",
      "color": "#C82909",
      "strikethrough": false
    }
  ],
  // =========================================
  // MARKDOWN SETTINGS
  // =========================================
  "workbench.editorAssociations": {
    "*.md": "vscode.markdown.preview.editor",
  },
  // =========================================
  // PROTOBUF SETTINGS
  // =========================================
  "protobuf.protoc.path": "/usr/bin/protoc",
  "json.schemaDownload.trustedDomains": {
    "https://developer.microsoft.com/json-schemas/": true,
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://raw.githubusercontent.com/devcontainers/spec/": true,
    "https://raw.githubusercontent.com/microsoft/vscode/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://turborepo.com": true,
    "https://www.schemastore.org/": true
  },
  "workbench.layoutControl.enabled": false,
  "workbench.navigationControl.enabled": false,
  // =========================================
  // PYTHON SETTINGS
  // =========================================
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    },
  },
  "isort.args": [
    "--profile",
    "black"
  ],
  // =========================================
  // MISC
  // =========================================
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    "*.asax": "$(capture).*.cs, $(capture).*.vb",
    "*.ascx": "$(capture).*.cs, $(capture).*.vb",
    "*.ashx": "$(capture).*.cs, $(capture).*.vb",
    "*.aspx": "$(capture).*.cs, $(capture).*.vb",
    "*.bloc.dart": "$(capture).event.dart, $(capture).state.dart",
    "*.c": "$(capture).h",
    "*.cc": "$(capture).hpp, $(capture).h, $(capture).hxx",
